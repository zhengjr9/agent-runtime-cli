    "@anthropic-ai/vertex-sdk": "file:./shims/anthropic-vertex-sdk",
    "@aws-sdk/client-bedrock": "file:./shims/aws-sdk-client-bedrock",
    "@aws-sdk/client-bedrock-runtime": "*",
    "@aws-sdk/client-sts": "file:./shims/aws-sdk-client-sts",
    "@azure/identity": "file:./shims/azure-identity",
    "@commander-js/extra-typings": "*",
    "@growthbook/growthbook": "*",
    "@modelcontextprotocol/sdk": "*",
    "@opentelemetry/api": "file:./shims/opentelemetry-api",
