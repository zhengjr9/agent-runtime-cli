{
  "name": "agent-runtime-cli",
  "version": "0.2.0",
  "private": true,
  "description": "Standalone REPL for agent-runtime A2A",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhengjr9/agent-runtime-cli.git"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=24.0.0"
  },
  "scripts": {
    "bridge": "bun run ./src/a2a/bridgeServer.ts",
    "a2a-connect": "bun run ./src/agent-cli.tsx",
    "dev": "bun run ./src/agent-cli.tsx",
    "start": "bun run ./src/agent-cli.tsx",
    "cli": "bun run ./src/agent-cli.tsx",
    "build": "mkdir -p dist && bun build ./src/agent-cli.tsx --compile --outfile dist/agent-cli",
    "package:mac": "mkdir -p dist && bun build ./src/agent-cli.tsx --compile --outfile dist/agent-cli && codesign --force --sign - dist/agent-cli && env LC_ALL=C LANG=C tar -czf dist/agent-cli-darwin-arm64.tar.gz -C dist agent-cli && /usr/bin/openssl dgst -sha256 dist/agent-cli dist/agent-cli-darwin-arm64.tar.gz > dist/agent-cli-darwin-arm64.sha256",
    "version": "bun run ./src/dev-entry.ts --version"
  },
  "bin": {
    "agent-cli": "./src/agent-cli.tsx"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "*",
    "@ant/claude-for-chrome-mcp": "file:./shims/ant-claude-for-chrome-mcp",
    "@ant/computer-use-input": "file:./shims/ant-computer-use-input",
